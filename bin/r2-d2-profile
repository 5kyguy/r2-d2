#!/bin/bash

R2D2_PATH="${R2D2_PATH:-$HOME/.local/share/r2-d2}"
# shellcheck source=../install/helpers/profile.sh
source "$R2D2_PATH/install/helpers/profile.sh"

usage() {
  echo "Usage: r2-d2-profile get|set <desktop|server>"
  exit 1
}

case "${1:-}" in
  get)
    r2d2_profile
    ;;
  set)
    [[ $# -eq 2 ]] || usage
    case "$2" in
      desktop | server) ;;
      *) usage ;;
    esac
    mkdir -p "$(dirname "$R2D2_PROFILE_FILE")"
    echo "$2" >"$R2D2_PROFILE_FILE"
    ;;
  *)
    usage
    ;;
esac