#!/bin/bash

# Submit a preset bench task to K-2SO by id (see config/k2so/bench-presets.json).

if [[ -z $1 ]]; then
  echo "Usage: r2-d2-k2so-bench-preset <id>" >&2
  echo "Presets:" >&2
  jq -r '.[] | "  \(.id) — \(.instruction)"' "${R2D2_PATH:-$HOME/.local/share/r2-d2}/config/k2so/bench-presets.json"
  exit 1
fi

presets="${R2D2_PATH:-$HOME/.local/share/r2-d2}/config/k2so/bench-presets.json"
instruction=$(jq -r --arg id "$1" '.[] | select(.id == $id) | .instruction' "$presets")
task_type=$(jq -r --arg id "$1" '.[] | select(.id == $id) | .taskType // "background"' "$presets")

if [[ -z $instruction || $instruction == null ]]; then
  echo "Unknown preset: $1" >&2
  exit 1
fi

k2so ask --type "$task_type" "$instruction"
