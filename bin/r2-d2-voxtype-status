#!/bin/bash

# Clean up the voxtype status --follow child when this process exits (e.g. when
# waybar reloads). Without this, long K-2SO sessions accumulate zombie voxtype
# status processes. Port of omarchy 37189368.
trap 'kill 0' EXIT

if r2-d2-cmd-present voxtype; then
  voxtype status --follow --extended --format json | while read -r line; do
    echo "$line" | jq -c '. + {alt: .class}'
  done
else
  echo '{"alt": "", "tooltip": ""}'
fi
