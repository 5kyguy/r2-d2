#!/bin/bash

# Ensure ~/.config/r2-d2/zai-api-key exists (raw key file for OpenCode {file:...}).
# Migrates a key from legacy ~/.config/r2-d2/k2so.env when present.

set -euo pipefail

secrets_dir="${HOME}/.config/r2-d2"
key_file="${secrets_dir}/zai-api-key"
legacy_env="${secrets_dir}/k2so.env"

mkdir -p "$secrets_dir"

if [[ -f $legacy_env && ! -s $key_file ]]; then
  line=$(grep -E '^[[:space:]]*ZAI_API_KEY=' "$legacy_env" | head -1 || true)
  if [[ -n $line ]]; then
    value="${line#*=}"
    value="${value%\"}"
    value="${value#\"}"
    value="${value%\'}"
    value="${value#\'}"
    if [[ -n $value ]]; then
      printf '%s' "$value" >"$key_file"
      chmod 600 "$key_file"
      echo "Migrated Z.AI API key from $legacy_env -> $key_file"
    fi
  fi
fi

if [[ ! -f $key_file ]]; then
  install -m 600 /dev/null "$key_file"
  echo "Created $key_file — add your Z.AI API key (raw value, one line)"
fi
