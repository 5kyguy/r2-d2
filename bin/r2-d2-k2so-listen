#!/bin/bash

# Push-to-talk style voice ingress for K-2SO via Voxtype.
# Interactive stop (read) needs a TTY — re-open in a floating terminal when
# launched from a Hyprland keybind.

if [[ ! -t 0 ]]; then
  exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.r2d2.terminal --title=K-2SO -e r2-d2-k2so-listen
fi

if ! r2-d2-cmd-present k2so; then
  notify-send "K-2SO" "k2so not found — run r2-d2-install-k2so first" -u critical -t 5000
  exit 1
fi

if r2-d2-cmd-missing voxtype; then
  notify-send "K-2SO" "Voxtype not installed — run r2-d2-voxtype-install" -u critical -t 5000
  exit 1
fi

if ! pgrep -x voxtype >/dev/null; then
  notify-send "K-2SO" "Voxtype daemon is not running" -u critical -t 5000
  exit 1
fi

clipboard_before=$(wl-paste 2>/dev/null || true)

r2-d2-notification-send -g 󰫋 "K-2SO" "Listening…" -t 2000
voxtype record start

echo "Press any key to stop recording…" >&2
read -rsn1 -s

voxtype record stop
sleep 1

instruction=$(wl-paste 2>/dev/null || true)
if [[ -z $instruction ]]; then
  instruction=$(gum input --prompt "K-2SO> " --placeholder "Voice not captured — type instruction…")
fi
if [[ -z $instruction ]]; then
  exit 0
fi

if [[ -n $clipboard_before ]]; then
  printf '%s' "$clipboard_before" | wl-copy
fi

if k2so ask "$instruction"; then
  r2-d2-notification-send -g 󰚩 "K-2SO" "Task queued from voice" -t 3000
else
  r2-d2-notification-send -g 󰚩 --urgency critical "K-2SO" "Failed to queue task — is k2so serve running?" -t 5000
  exit 1
fi
