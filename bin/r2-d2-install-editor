#!/bin/bash

# Install one of the supported editors. Usually called via Install > Editor in the R2-D2 Menu.

if [[ -z $1 ]]; then
  echo "Usage: r2-d2-install-editor <vscode|t3code>" >&2
  exit 1
fi

case "$1" in
vscode)
  echo -e "Installing VS Code...\n"
  r2-d2-pkg-aur-add visual-studio-code-bin
  ;;
t3code)
  echo -e "Installing T3 Code...\n"
  r2-d2-pkg-aur-add t3code-bin
  ;;
*)
  echo "Unknown editor: $1" >&2
  exit 1
  ;;
esac
