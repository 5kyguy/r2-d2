#!/bin/bash

# Send an R2-D2 desktop notification with optional glyph, image, and click
# action support. Wraps notify-send so callers (including the K-2SO agent via
# MCP tools) have one consistent API.
#
# Usage:
#   r2-d2-notification-send [-a] [--app-name <name>] [-g <glyph>] \
#     [-u <low|normal|critical>] [--image <path-or-uri>] \
#     <headline> [description] [notify-send options]
#
# -a / --action     register a default click action; echoes "default" if clicked
# -g / --glyph      nerd-font glyph rendered compactly (hint: r2-d2-glyph)
# --image           attach an image thumbnail (hint: image-path)
# --app-name        override the app-name tag (default: r2-d2-action)
# -u / --urgency    notify-send urgency (default: low)
#
# Port of omarchy af5e918d. mako honors all hints used here.

set -euo pipefail

headline=""
description=""
glyph=
urgency="low"
app_name="r2-d2-action"
image=
click_action=0
args=()
parsed_option_args=0

parse_r2d2_option() {
  case $1 in
  -g | --glyph)
    if (($# < 2)); then
      echo "Missing value for $1" >&2
      exit 1
    fi
    glyph=$2
    parsed_option_args=2
    return 0
    ;;
  -u | --urgency)
    if (($# < 2)); then
      echo "Missing value for $1" >&2
      exit 1
    fi
    urgency="$2"
    parsed_option_args=2
    return 0
    ;;
  --app-name)
    if (($# < 2)); then
      echo "Missing value for $1" >&2
      exit 1
    fi
    app_name=$2
    parsed_option_args=2
    return 0
    ;;
  --image)
    if (($# < 2)); then
      echo "Missing value for $1" >&2
      exit 1
    fi
    image=$2
    parsed_option_args=2
    return 0
    ;;
  -a | --action)
    click_action=1
    parsed_option_args=1
    return 0
    ;;
  esac

  return 1
}

while (($# > 0)); do
  if parse_r2d2_option "$@"; then
    shift "$parsed_option_args"
  else
    break
  fi
done

if (($# < 1)); then
  echo "Usage: r2-d2-notification-send [-a] [--app-name <name>] [-g <glyph>] [-u <low|normal|critical>] [--image <path-or-uri>] <headline> [description] [notify-send options]" >&2
  exit 1
fi

headline=$1
shift

if (($# > 0)) && [[ $1 != -* ]]; then
  description=$1
  shift
fi

while (($# > 0)); do
  if parse_r2d2_option "$@"; then
    shift "$parsed_option_args"
  else
    args+=("$1")
    shift
  fi
done

# Tag as a user-action toast so it pops through DND.
args+=("-a" "$app_name" "-u" "$urgency")

if [[ -n $glyph ]]; then
  args+=("--hint=string:r2-d2-glyph:$glyph")
fi

if [[ -n $image ]]; then
  args+=("--hint=string:image-path:$image")
fi

if ((click_action)); then
  args+=("-A" "default=default")
fi

if [[ -n $description ]]; then
  notify-send "${args[@]}" "$headline" "$description"
else
  notify-send "${args[@]}" "$headline"
fi
