#!/bin/bash

# Install K-2SO companion agent and R2-D2 MCP integration.

if gum confirm "Install K-2SO background agent (Node.js, builds from k-2so repo)?"; then
  bash "${R2D2_PATH:-$HOME/.local/share/r2-d2}/install/packaging/k2so.sh"
  notify-send "K-2SO" "Installed. Super+A to ask, Super+Shift+A for voice.\nAdd your Z.AI key to ~/.config/r2-d2/zai-api-key" -t 12000
fi
