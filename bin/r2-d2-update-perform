#!/bin/bash

set -e

BIN="$(dirname "$0")"

# Ensure screensaver/sleep doesn't set in during updates
hyprctl dispatch tagwindow +noidle &>/dev/null || true

# Capture update logs
export CLICOLOR_FORCE=1
exec > >(tee "/tmp/r2-d2-update.log") 2>&1

# Perform all update steps (invoke by path so this works when run from menu without bin in PATH)
[[ -n $R2D2_UPDATE_SKIP_TIME ]] || "$BIN/r2-d2-update-time"
[[ -n $R2D2_UPDATE_SKIP_KEYRING ]] || "$BIN/r2-d2-update-keyring"
[[ -n $R2D2_UPDATE_SKIP_AVAILABLE_RESET ]] || "$BIN/r2-d2-update-available-reset"
[[ -n $R2D2_UPDATE_SKIP_SYNC_FILES ]] || "$BIN/r2-d2-update-sync-files"
[[ -n $R2D2_UPDATE_SKIP_SYSTEM_PKGS ]] || "$BIN/r2-d2-update-system-pkgs"
[[ -n $R2D2_UPDATE_SKIP_SYNC_PKGS ]] || "$BIN/r2-d2-update-sync-pkgs"
[[ -n $R2D2_UPDATE_SKIP_MIGRATE ]] || "$BIN/r2-d2-migrate"
[[ -n $R2D2_UPDATE_SKIP_AUR_PKGS ]] || "$BIN/r2-d2-update-aur-pkgs"
[[ -n $R2D2_UPDATE_SKIP_ORPHAN_PKGS ]] || "$BIN/r2-d2-update-orphan-pkgs"
[[ -n $R2D2_UPDATE_SKIP_HOOK ]] || "$BIN/r2-d2-hook" post-update

"$BIN/r2-d2-update-analyze-logs"

"$BIN/r2-d2-update-restart"

# Re-enable screensaver/sleep after updates
hyprctl dispatch tagwindow -- -noidle &>/dev/null || true
