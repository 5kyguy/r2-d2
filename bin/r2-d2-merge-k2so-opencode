#!/bin/bash

# Merge R2-D2's r2d2 MCP block into ~/.config/opencode/opencode.json.
# Never replaces an existing provider/model setup — only adds mcp.r2d2.
# K-2SO agent registration is owned by k2so init (~/.config/opencode/agents/k2so.md).

set -euo pipefail

R2D2_PATH="${R2D2_PATH:-$HOME/.local/share/r2-d2}"
user_config="${HOME}/.config/opencode/opencode.json"
repo_config="${R2D2_PATH}/config/opencode/opencode.json"
zai_key_file="${HOME}/.config/r2-d2/zai-api-key"

if ! command -v jq &>/dev/null; then
  echo "r2-d2-merge-k2so-opencode: jq is required" >&2
  exit 1
fi

mkdir -p "$(dirname "$user_config")"

if [[ ! -f $user_config ]]; then
  cp "$repo_config" "$user_config"
  echo "Installed default OpenCode config -> $user_config"
  exit 0
fi

tmp="${user_config}.tmp.$$"
jq -s --arg key_file "$zai_key_file" '
  .[0] as $user |
  .[1] as $repo |
  $user |
  .mcp = (($user.mcp // {}) + { r2d2: $repo.mcp.r2d2 }) |
  if (.provider["zai-coding"].options.apiKey? == "{env:ZAI_API_KEY}") then
    .provider["zai-coding"].options.apiKey = "{file:\($key_file)}"
  else . end
' "$user_config" "$repo_config" >"$tmp"
mv "$tmp" "$user_config"
echo "Merged r2d2 MCP block into $user_config (provider/model unchanged)"