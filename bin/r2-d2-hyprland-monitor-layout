#!/bin/bash
# Apply a monitor layout preset so cursor movement matches physical placement.
# With HDMI on the left of the laptop: external left, built-in (eDP) right.
# Usage: r2-d2-hyprland-monitor-layout [preset]
#   preset: external-left (default) | external-right

set -e

PRESET="${1:-external-left}"

MONITORS_JSON=$(hyprctl monitors -j 2>/dev/null) || {
  echo "hyprctl failed" >&2
  exit 1
}
COUNT=$(echo "$MONITORS_JSON" | jq 'length')
if ((COUNT < 2)); then
  notify-send "Monitor layout" "Connect 2 monitors to apply a layout preset."
  exit 0
fi

# Classify: built-in (eDP) vs external (HDMI, DP, etc.)
BUILTIN=$(echo "$MONITORS_JSON" | jq -r '.[] | select(.name | test("eDP"; "i")) | .name' | head -1)
EXTERNAL=$(echo "$MONITORS_JSON" | jq -r '.[] | select(.name | test("eDP"; "i") | not) | .name' | head -1)

if [[ -z $BUILTIN ]] || [[ -z $EXTERNAL ]]; then
  # More than two outputs or naming we don't recognise: list and exit
  notify-send "Monitor layout" "Could not identify exactly one eDP and one external. Run: hyprctl monitors"
  exit 1
fi

# Monitor rule: name, WIDTHxHEIGHT@REFRESH, POSxPOS, scale
monitor_rule() {
  local name="$1" res="$2" pos="$3" scale="$4"
  echo "${name},${res},${pos},${scale}"
}

# Res string: WIDTHxHEIGHT@REFRESH (integer refresh)
res_spec() {
  local name="$1"
  echo "$MONITORS_JSON" | jq -r --arg n "$name" '.[] | select(.name == $n) | "\(.width)x\(.height)@\(.refreshRate | floor)"'
}

EXT_RES=$(res_spec "$EXTERNAL")
BUI_RES=$(res_spec "$BUILTIN")
EXT_W=$(echo "$MONITORS_JSON" | jq -r --arg n "$EXTERNAL" '.[] | select(.name == $n) | .width')
EXT_SCALE=$(echo "$MONITORS_JSON" | jq -r --arg n "$EXTERNAL" '.[] | select(.name == $n) | .scale')
BUI_SCALE=$(echo "$MONITORS_JSON" | jq -r --arg n "$BUILTIN" '.[] | select(.name == $n) | .scale')
# Position in layout uses scaled (logical) pixels
EXT_LOGICAL_W=$(awk "BEGIN { printf \"%.0f\", $EXT_W / $EXT_SCALE }")
BUI_W=$(echo "$MONITORS_JSON" | jq -r --arg n "$BUILTIN" '.[] | select(.name == $n) | .width')
BUI_LOGICAL_W=$(awk "BEGIN { printf \"%.0f\", $BUI_W / $BUI_SCALE }")

case "$PRESET" in
external-left)
  # External at 0x0, built-in to its right
  hyprctl keyword monitor "$(monitor_rule "$EXTERNAL" "$EXT_RES" "0x0" "$EXT_SCALE")"
  hyprctl keyword monitor "$(monitor_rule "$BUILTIN" "$BUI_RES" "${EXT_LOGICAL_W}x0" "$BUI_SCALE")"
  notify-send "Monitor layout" "External left, laptop right"
  ;;
external-right)
  # Built-in at 0x0, external to its right
  hyprctl keyword monitor "$(monitor_rule "$BUILTIN" "$BUI_RES" "0x0" "$BUI_SCALE")"
  hyprctl keyword monitor "$(monitor_rule "$EXTERNAL" "$EXT_RES" "${BUI_LOGICAL_W}x0" "$EXT_SCALE")"
  notify-send "Monitor layout" "Laptop left, external right"
  ;;
*)
  echo "Unknown preset: $PRESET. Use: external-left | external-right" >&2
  exit 1
  ;;
esac
