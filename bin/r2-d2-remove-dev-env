#!/bin/bash

# Remove a development environment that was previously installed via r2-d2-install-dev-env.
# Usage: r2-d2-remove-dev-env <node|go|python|rust>

if [[ -z $1 ]]; then
  echo "Usage: r2-d2-remove-dev-env <node|go|python|rust>" >&2
  exit 1
fi

case "$1" in
node)
  echo -e "Removing Node.js (nvm)...\n"
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [[ -s $NVM_DIR/nvm.sh ]]; then
    source "$NVM_DIR/nvm.sh"
    def=$(nvm version default 2>/dev/null)
    [[ -n $def ]] && nvm uninstall "$def" 2>/dev/null || true
    nvm alias default '' 2>/dev/null || true
  fi
  ;;
go)
  echo -e "Removing Go (/usr/local/go)...\n"
  sudo rm -rf /usr/local/go
  sudo rm -f /etc/profile.d/go.sh
  ;;
python)
  echo -e "Removing Python (packages) and uv...\n"
  r2-d2-pkg-drop python
  rm -rf ~/.local/bin/uv ~/.local/bin/uvx ~/.cargo/bin/uv 2>/dev/null || true
  ;;
rust)
  echo -e "Removing Rust...\n"
  rustup self uninstall -y 2>/dev/null || true
  ;;
*)
  echo "Unknown environment: $1" >&2
  exit 1
  ;;
esac

echo -e "\nDone!"
