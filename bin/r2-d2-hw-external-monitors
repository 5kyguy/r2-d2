#!/bin/bash

# Returns true when an external monitor is physically connected.
# Used to guard lid-close behavior so closing the lid with no external
# display doesn't kill the only active screen.
# Port of omarchy omarchy-hw-external-monitors.

for status in /sys/class/drm/card*-*/status; do
  [[ $status == *-eDP-*/status ]] && continue
  [[ $(< $status) == "connected" ]] && exit 0
done
exit 1
