#!/bin/bash

# Run user hooks for the given hook name.
# Usage: r2-d2-hook <hookname>
# Runs each executable in ~/.local/share/r2-d2/hooks/<hookname>/ in order.
# No-op if the directory does not exist or is empty.

hook_name=$1
if [[ -z $hook_name ]]; then
  echo "Usage: $0 <hookname> [args...]" >&2
  exit 1
fi
shift

R2D2_PATH="${R2D2_PATH:-$HOME/.local/share/r2-d2}"
hooks_dir="$R2D2_PATH/hooks/$hook_name"

[[ ! -d $hooks_dir ]] && exit 0

for f in "$hooks_dir"/*; do
  [[ -x $f && -f $f ]] || continue
  "$f" "$@" || true
done
