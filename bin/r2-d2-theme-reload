#!/bin/bash

# Reload desktop components after the user applies an update (optional desktop refresh prompt).
# Do not call from theme-apply, migrations, or wallpaper changes.

set -euo pipefail

accent="${1:-}"

hyprctl reload >/dev/null 2>&1 || true
r2-d2-restart-waybar >/dev/null 2>&1 || true
r2-d2-restart-mako >/dev/null 2>&1 || true
r2-d2-restart-walker >/dev/null 2>&1 || true
r2-d2-restart-swayosd >/dev/null 2>&1 || true

if [[ -n $accent ]] && command -v notify-send >/dev/null 2>&1; then
  notify-send "R2-D2 theme" "Accent: $accent" -t 2500
fi