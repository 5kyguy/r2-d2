#!/bin/bash

# Sets the specified image as the default background (symlink + swaybg only).
# Theme colors are regenerated in the repo and applied to ~/.config on r2-d2-update.

if [[ -z $1 ]]; then
  echo "Usage: r2-d2-theme-bg-set <path-to-image>" >&2
  exit 1
fi

BACKGROUND="$1"
R2D2_ROOT="${R2D2_PATH:-$HOME/.local/share/r2-d2}"
BACKGROUND_DIR="$R2D2_ROOT/backgrounds"
BACKGROUND_LINK="$BACKGROUND_DIR/@background"

mkdir -p "$BACKGROUND_DIR"

# Create/update symlink to the new background inside backgrounds/
ln -nsf "$BACKGROUND" "$BACKGROUND_LINK"

# Kill existing swaybg and start new one
pkill -x swaybg
setsid uwsm-app -- swaybg -i "$BACKGROUND_LINK" -m fill >/dev/null 2>&1 &
