/* R2-D2 companion theme: dark base + wallpaper-driven accent */
@define-color background {{BACKGROUND}};
@define-color waybarBg rgba({{BACKGROUND_R}}, {{BACKGROUND_G}}, {{BACKGROUND_B}}, 0.85);
@define-color foreground {{FOREGROUND}};
@define-color surface #636e72;
@define-color inactive {{INACTIVE}};

@define-color accent_orange {{WARNING}};
@define-color accent_green {{ACCENT}};
@define-color accent_blue {{ACCENT}};
@define-color accent_critical {{CRITICAL}};

#waybar {
  background-color: @waybarBg;
}

#battery.charging,
#battery.plugged {
  color: @accent_green;
}

#battery.warning:not(.charging) {
  color: @accent_orange;
}

#battery.critical:not(.charging) {
  color: @accent_critical;
}

#pulseaudio.muted {
  color: @accent_critical;
}

#network.disconnected {
  color: @accent_critical;
}

tooltip {
  background-color: @waybarBg;
  padding: 8px 12px;
  border: 1px solid @accent_blue;
}

tooltip label {
  color: @foreground;
}

#tray menu {
  background-color: @waybarBg;
  color: @foreground;
  border: 1px solid @accent_blue;
}